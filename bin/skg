    lb.add_argument("--out", required=True)
    lb.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lb.add_argument("--run-id", default=None)
    lb.add_argument("--workload-id", default=None)
    ll = lis.add_parser("ldapdomaindump")
    ll.add_argument("--dump-dir", required=True, dest="dump_dir")
    ll.add_argument("--out", required=True)
    ll.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    ll.add_argument("--run-id", default=None)
    ll.add_argument("--workload-id", default=None)
    lm = lis.add_parser("manual")
    lm.add_argument("--input", required=True)
    lm.add_argument("--out", required=True)
    lm.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lm.add_argument("--run-id", default=None)
    lm.add_argument("--workload-id", default=None)
    lpr = lps.add_parser("project")
    lpr.add_argument("--in", dest="infile", required=True)
    lpr.add_argument("--out", dest="outfile", required=True)
    lpr.add_argument("--attack-path-id", required=True)
    ll2 = lps.add_parser("latest")
    ll2.add_argument("--interp", required=True)
    ll2.add_argument("--attack-path-id", required=True)
    ll2.add_argument("--workload-id", default=None)

    a = p.parse_args()
    dispatch = {
        "start":     cmd_start,
        "stop":      cmd_stop,
        "status":    cmd_status,
        "surface":   cmd_surface,
        "web":       cmd_web_view,
        "target":    cmd_target,
        "observe":   cmd_observe,
        "gravity":   cmd_gravity,
        "proposals": cmd_proposals,
