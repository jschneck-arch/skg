#!/opt/skg/.venv/bin/python3
"""
skg — Unified CLI for Semantic Kernel Gravity

DAEMON (requires running daemon on 127.0.0.1:5055):
  skg status
  skg mode [kernel|resonance|unified|anchor] [--reason "..."]
  skg identity [history]

RESONANCE (runs directly, no daemon needed):
  skg resonance status
  skg resonance ingest
  skg resonance query <text> [--type all|wickets|adapters|domains] [--k N]
  skg resonance draft <domain> <description> [--api-key KEY]
  skg resonance drafts

APRS:
  skg aprs ingest config_effective --root <path> --out <file> [options]
  skg aprs ingest net_sandbox --docker-inspect <path> --out <file> [options]
  skg aprs project --in <events> --out <interp> --attack-path-id <id>
  skg aprs latest --interp <file> --attack-path-id <id>
  skg aprs paths

CONTAINER ESCAPE:
  skg escape ingest --inspect <path> --out <file> [options]
  skg escape project --in <events> --out <interp> --attack-path-id <id>
  skg escape latest --interp <file> --attack-path-id <id>
  skg escape paths

AD LATERAL:
  skg lateral ingest bloodhound --bh-dir <path> --out <file> [options]
  skg lateral ingest ldapdomaindump --dump-dir <path> --out <file> [options]
  skg lateral ingest manual --input <path> --out <file> [options]
  skg lateral project --in <events> --out <interp> --attack-path-id <id>
  skg lateral latest --interp <file> --attack-path-id <id>
  skg lateral paths
"""
import json, sys, argparse, subprocess, urllib.request, urllib.error
from pathlib import Path

API      = "http://127.0.0.1:5055"
SKG_HOME = Path("/opt/skg")


def _api(method, path, data=None, params=None):
    if params:
        import urllib.parse as _uparse
        url = f"{API}{path}?" + _uparse.urlencode({k:v for k,v in params.items() if v is not None})
    else:
        url  = f"{API}{path}"
    body = json.dumps(data).encode() if data else None
    hdrs = {"Content-Type": "application/json"} if body else {}
    req  = urllib.request.Request(url, data=body, headers=hdrs, method=method)
    try:
        with urllib.request.urlopen(req, timeout=5) as r:
            return json.loads(r.read())
    except urllib.error.URLError:
        print("Error: SKG daemon not running.  Start: systemctl --user start skg")
        sys.exit(1)
    except urllib.error.HTTPError as e:
        print(f"Error: {json.loads(e.read()).get('detail', str(e))}")
        sys.exit(1)


def _tc(tc_name, cli_script, *args):
    tc_dir = SKG_HOME / tc_name
    py     = tc_dir / ".venv" / "bin" / "python"
    cli    = tc_dir / cli_script
    if not py.exists():
        print(f"Error: {tc_name} not bootstrapped.\n  cd {tc_dir} && ./bootstrap.sh")
        return 1
    return subprocess.call([str(py), str(cli)] + list(args), cwd=str(tc_dir))


def _aprs(*args):    return _tc("skg-aprs-toolchain",             "skg.py",         *args)
def _escape(*args):  return _tc("skg-container-escape-toolchain", "skg_escape.py",  *args)
def _lateral(*args): return _tc("skg-ad-lateral-toolchain",       "skg_lateral.py", *args)


def _resonance_engine():
    sys.path.insert(0, str(SKG_HOME))
    from skg.resonance.engine import ResonanceEngine
    from skg.core.paths import RESONANCE_DIR
    engine = ResonanceEngine(RESONANCE_DIR)
    engine.boot()
    return engine


# ---------------------------------------------------------------------------
# Daemon commands
# ---------------------------------------------------------------------------



def cmd_field(a):
    """Display projection engine field state for a workload — not a findings list."""
    import math as _math
    wid    = a.workload_id
    domain = getattr(a, "domain", "host") or "host"
    try:
        d = _api("GET", f"/projections/{wid}/field", params={"domain": domain})
    except Exception as exc:
        print(f"  Error: {exc}")
        print(f"  Tip: try 'skg status' to confirm daemon is running")
        sys.exit(1)

    E     = d.get("E", 0.0)
    E_max = _math.log2(3)
    fill  = int((1.0 - min(E, E_max) / E_max) * 30)
    bar   = "#" * fill + "-" * (30 - fill)

    cls_map = {
        "realized":      "EMERGENT      — all preconditions satisfied",
        "collapsed":     "COLLAPSED     — structural constraint prevents realization",
        "indeterminate": "INDETERMINATE — unknown nodes prevent determination",
    }
    cls       = d.get("classification", "?")
    cls_label = cls_map.get(cls.lower(), cls.upper())

    print(f"\n{'='*64}")
    print(f"  SKG Projection Engine  —  not a findings list")
    print(f"{'-'*64}")
    print(f"  Path     : {d.get('attack_path_id','?')}")
    print(f"  Workload : {wid}  |  Domain: {domain}")
    print(f"  Outcome  : {cls_label}")
    print(f"{'-'*64}")
    print(f"  E = {E:.4f}  (field energy; 0.000 = fully determined)")
    print(f"  [{bar}]  {d.get('n_realized',0)}R {d.get('n_blocked',0)}B {d.get('n_unknown',0)}U / {d.get('n_required',0)} required")
    print(f"{'-'*64}")

    for w in d.get("realized_nodes", []):
        print(f"    [R]  {w}")
    for w in d.get("blocked_nodes", []):
        print(f"    [B]  {w}")

    hints = d.get("resolution_required", {})
    for w in d.get("unknown_nodes", []):
        print(f"    [U]  {w}")
        print(f"         -> {hints.get(w, 'sensor sweep required')}")

    history = d.get("state_transition_history", [])
    if len(history) > 1:
        print(f"{'-'*64}")
        print(f"  History ({len(history)} sweeps, last 5):")
        for h in history[-5:]:
            ts   = h.get("computed_at", "")[:19].replace("T", " ")
            e_h  = h.get("E", 0.0)
            fill2 = int((1.0 - min(e_h, E_max) / E_max) * 15)
            e_bar = "#" * fill2 + "-" * (15 - fill2)
            print(f"    {ts}  E={e_h:.3f} [{e_bar}]  "
                  f"{h.get('n_realized',0)}R {h.get('n_blocked',0)}B {h.get('n_unknown',0)}U  "
                  f"{h.get('classification','?')[:4].upper()}")
    print(f"{'='*64}\n")

def cmd_status(a):
    d = _api("GET", "/status")
    print(f"  Status  : {d['status']}")
    print(f"  Mode    : {d['mode']} — {d['mode_description']}")
    print(f"  TC runs : {'enabled' if d['toolchain_runs_enabled'] else 'disabled in this mode'}")
    print(f"  Started : {d['started_at']}")
    print()
    print("  Toolchains:")
    for domain, status in d.get("toolchains", {}).items():
        print(f"    {domain}: {status}")
    print()
    rs = d.get("resonance", {})
    if rs.get("ready"):
        mem = rs.get("memory", {})
        print(f"  Resonance: ready ({rs.get('embedder','?')} dim={rs.get('dim','?')})")
        print(f"    wickets={mem.get('wickets',0)} "
              f"adapters={mem.get('adapters',0)} "
              f"domains={mem.get('domains',0)}")
    else:
        print(f"  Resonance: {rs.get('reason', 'not ready')}")
    print()
    i = d['identity']
    print(f"  Identity: {i['name']} v{i['version']} | "
          f"coherence={i['coherence']} | sessions={i['sessions']}")
    fs = d.get("field_state", {})
    if fs:
        import math as _math
        E_max = _math.log2(3)
        print(f"  Field state ({len(fs)} paths):")
        for k, v in sorted(fs.items()):
            E = v.get("E", 0.0)
            fill = int((1.0 - min(E, E_max) / E_max) * 20)
            bar = "#" * fill + "-" * (20 - fill)
            cls = v.get("classification", "?")[:4].upper()
            nu  = v.get("n_unknown", 0)
            nr  = v.get("n_realized", 0)
            nb  = v.get("n_blocked", 0)
            print(f"    [{bar}] E={E:.3f} {cls}  {nr}R {nb}B {nu}U  {k}")
            for w in v.get("unknown_nodes", []):
                hint = v.get("resolution_required", {}).get(w, "")
                print(f"      [U] {w} -> {hint}")

def cmd_mode(a):
    if a.set_mode:
        t = _api("POST", "/mode", {"mode": a.set_mode, "reason": a.reason or ""})["transition"]
        print(f"  Mode: {t['from']} -> {t['to']}" +
              (f"\n  Reason: {t['reason']}" if t.get("reason") else ""))
    else:
        d = _api("GET", "/mode")
        print(f"  Mode: {d['mode']}\n  {d['description']}")


def cmd_identity(a):
    if getattr(a, "subcommand", None) == "history":
        for r in _api("GET", "/identity/history"):
            print(f"  [{r['timestamp']}] mode={r['mode']} "
                  f"coherence={r['coherence']} src={r['source']}")
    else:
        for k, v in _api("GET", "/identity").items():
            if k not in ("timestamp", "source"):
                print(f"  {k}: {v}")


# ---------------------------------------------------------------------------
# Resonance commands (direct — no daemon needed)
# ---------------------------------------------------------------------------

def cmd_resonance(a):
    subcmd = a.resonance_cmd

    if subcmd == "status":
        engine = _resonance_engine()
        print(json.dumps(engine.status(), indent=2))

    elif subcmd == "ingest":
        from skg.resonance.ingester import ingest_all
        from skg.core.paths import RESONANCE_DIR
        engine = _resonance_engine()
        summary = ingest_all(engine, SKG_HOME)
        print(json.dumps(summary, indent=2))

    elif subcmd == "query":
        engine = _resonance_engine()
        k = getattr(a, "k", 5) or 5
        qtype = getattr(a, "type", "all") or "all"
        if qtype in ("wickets", "all"):
            results = engine.query_wickets(a.text, k=k)
            print(f"\n=== Wickets (top {len(results)}) ===")
            for rec, score in results:
                print(f"  [{score:.3f}] {rec.record_id}")
                print(f"    {rec.label}")
                print(f"    {rec.description[:80]}")
        if qtype in ("adapters", "all"):
            results = engine.query_adapters(a.text, k=k)
            print(f"\n=== Adapters (top {len(results)}) ===")
            for rec, score in results:
                print(f"  [{score:.3f}] {rec.record_id}")
                print(f"    {'; '.join(rec.evidence_sources[:2])}")
        if qtype in ("domains", "all"):
            results = engine.query_domains(a.text, k=min(k, 3))
            print(f"\n=== Domains (top {len(results)}) ===")
            for rec, score in results:
                print(f"  [{score:.3f}] {rec.domain} — {rec.description[:80]}")

    elif subcmd == "draft":
        from skg.resonance.drafter import draft_catalog
        engine = _resonance_engine()
        print(f"[*] Drafting catalog for: {a.domain}")
        print(f"[*] Description: {a.description}")
        result = draft_catalog(engine, a.domain, a.description,
                               api_key=getattr(a, "api_key", None))
        errors = result["validation_errors"]
        if errors:
            print(f"\n[WARN] Validation issues ({len(errors)}):")
            for e in errors:
                print(f"  - {e}")
        else:
            print("\n[OK] Draft passed validation")
        ctx = result["context_used"]
        print(f"\n[*] Context: {ctx['wickets_surfaced']} wickets, "
              f"{ctx['adapters_surfaced']} adapters, "
              f"{ctx['domains_surfaced']} domains surfaced")
        print(f"[*] Wickets proposed:      {len(result['catalog'].get('wickets', {}))}")
        print(f"[*] Attack paths proposed: {len(result['catalog'].get('attack_paths', {}))}")
        print(f"\n[*] Draft saved: {result['draft_path']}")

    elif subcmd == "drafts":
        engine = _resonance_engine()
        drafts = engine.list_drafts()
        if not drafts:
            print("No pending drafts.")
            return
        print(f"{len(drafts)} pending draft(s):\n")
        for d in drafts:
            meta = d.get("meta", {})
            print(f"  {d['file']}")
            print(f"    domain:  {meta.get('domain', '?')}")
            print(f"    drafted: {meta.get('drafted_at', '?')}")
            print(f"    status:  {meta.get('status', '?')}")


# ---------------------------------------------------------------------------
# APRS
# ---------------------------------------------------------------------------

def cmd_aprs(a):
    subcmd = a.aprs_cmd
    if subcmd == "paths":
        sys.exit(_aprs("paths"))
    elif subcmd == "ingest":
        args = ["ingest", a.adapter, "--out", a.out,
                "--attack-path-id", a.attack_path_id]
        if getattr(a, "run_id",         None): args += ["--run-id",         a.run_id]
        if getattr(a, "workload_id",    None): args += ["--workload-id",    a.workload_id]
        if getattr(a, "root",           None): args += ["--root",           a.root]
        if getattr(a, "docker_inspect", None): args += ["--docker-inspect", a.docker_inspect]
        if getattr(a, "resolv_conf",    None): args += ["--resolv-conf",    a.resolv_conf]
        if getattr(a, "iptables",       None): args += ["--iptables",       a.iptables]
        if getattr(a, "ps",             None): args += ["--ps",             a.ps]
        sys.exit(_aprs(*args))
    elif subcmd == "project":
        sys.exit(_aprs("project", "aprs",
                       "--in", a.infile, "--out", a.outfile,
                       "--attack-path-id", a.attack_path_id))
    elif subcmd == "latest":
        args = ["latest", "--interp", a.interp, "--attack-path-id", a.attack_path_id]
        if a.workload_id: args += ["--workload-id", a.workload_id]
        sys.exit(_aprs(*args))


# ---------------------------------------------------------------------------
# Container escape
# ---------------------------------------------------------------------------

def cmd_escape(a):
    subcmd = a.escape_cmd
    if subcmd == "paths":
        sys.exit(_escape("paths"))
    elif subcmd == "ingest":
        args = ["ingest", "container_inspect",
                "--inspect", a.inspect, "--out", a.out,
                "--attack-path-id", a.attack_path_id]
        if getattr(a, "run_id",      None): args += ["--run-id",      a.run_id]
        if getattr(a, "workload_id", None): args += ["--workload-id", a.workload_id]
        sys.exit(_escape(*args))
    elif subcmd == "project":
        sys.exit(_escape("project",
                         "--in", a.infile, "--out", a.outfile,
                         "--attack-path-id", a.attack_path_id))
    elif subcmd == "latest":
        args = ["latest", "--interp", a.interp, "--attack-path-id", a.attack_path_id]
        if a.workload_id: args += ["--workload-id", a.workload_id]
        sys.exit(_escape(*args))


# ---------------------------------------------------------------------------
# AD lateral
# ---------------------------------------------------------------------------

def cmd_lateral(a):
    subcmd = a.lateral_cmd
    if subcmd == "paths":
        sys.exit(_lateral("paths"))
    elif subcmd == "ingest":
        adapter = a.lateral_adapter
        args = ["ingest", adapter, "--out", a.out,
                "--attack-path-id", a.attack_path_id]
        if getattr(a, "run_id",      None): args += ["--run-id",      a.run_id]
        if getattr(a, "workload_id", None): args += ["--workload-id", a.workload_id]
        if adapter == "bloodhound":
            args += ["--bh-dir",   a.bh_dir]
        elif adapter == "ldapdomaindump":
            args += ["--dump-dir", a.dump_dir]
        elif adapter == "manual":
            args += ["--input",    a.input]
        sys.exit(_lateral(*args))
    elif subcmd == "project":
        sys.exit(_lateral("project",
                          "--in", a.infile, "--out", a.outfile,
                          "--attack-path-id", a.attack_path_id))
    elif subcmd == "latest":
        args = ["latest", "--interp", a.interp, "--attack-path-id", a.attack_path_id]
        if a.workload_id: args += ["--workload-id", a.workload_id]
        sys.exit(_lateral(*args))


# ---------------------------------------------------------------------------
# Parser
# ---------------------------------------------------------------------------

def main():
    p   = argparse.ArgumentParser(prog="skg",
              description="SKG — Semantic Kernel Gravity")
    sub = p.add_subparsers(dest="command")

    # daemon
    sub.add_parser("status")

    mp = sub.add_parser("mode")
    mp.add_argument("set_mode", nargs="?",
                    choices=["kernel","resonance","unified","anchor"])
    mp.add_argument("--reason", default="")

    ip = sub.add_parser("identity")
    ip.add_argument("subcommand", nargs="?", choices=["history"])

    # resonance
    rp  = sub.add_parser("resonance")
    rps = rp.add_subparsers(dest="resonance_cmd", required=True)
    rps.add_parser("status")
    rps.add_parser("ingest")
    rq = rps.add_parser("query")
    rq.add_argument("text")
    rq.add_argument("--type", default="all",
                    choices=["all","wickets","adapters","domains"])
    rq.add_argument("--k", type=int, default=5)
    rd = rps.add_parser("draft")
    rd.add_argument("domain")
    rd.add_argument("description")
    rd.add_argument("--api-key", dest="api_key", default=None)
    rps.add_parser("drafts")

    # aprs
    fp  = sub.add_parser("field", help="projection engine field state (not a findings list)")
    fp.add_argument("workload_id", help="workload ID (e.g. archbox_self)")
    fp.add_argument("domain", nargs="?", default="host",
                    choices=["host", "container_escape", "ad_lateral", "aprs", "web", "supply_chain"],
                    help="domain (default: host)")
    ap  = sub.add_parser("aprs")
    aps = ap.add_subparsers(dest="aprs_cmd", required=True)
    aps.add_parser("paths")
    ai = aps.add_parser("ingest")
    ai.add_argument("adapter", choices=["config_effective","net_sandbox"])
    ai.add_argument("--out",            required=True)
    ai.add_argument("--attack-path-id", default="log4j_jndi_rce_v1")
    ai.add_argument("--run-id",         default=None)
    ai.add_argument("--workload-id",    default=None)
    ai.add_argument("--root",           default=None)
    ai.add_argument("--docker-inspect", dest="docker_inspect", default=None)
    ai.add_argument("--resolv-conf",    dest="resolv_conf",    default=None)
    ai.add_argument("--iptables",       default=None)
    ai.add_argument("--ps",             default=None)
    apr = aps.add_parser("project")
    apr.add_argument("--in",  dest="infile",  required=True)
    apr.add_argument("--out", dest="outfile", required=True)
    apr.add_argument("--attack-path-id", default="log4j_jndi_rce_v1")
    al = aps.add_parser("latest")
    al.add_argument("--interp",         required=True)
    al.add_argument("--attack-path-id", required=True)
    al.add_argument("--workload-id",    default=None)

    # escape
    ep  = sub.add_parser("escape")
    eps = ep.add_subparsers(dest="escape_cmd", required=True)
    eps.add_parser("paths")
    ei = eps.add_parser("ingest")
    ei.add_argument("--inspect",        required=True)
    ei.add_argument("--out",            required=True)
    ei.add_argument("--attack-path-id", default="container_escape_privileged_v1")
    ei.add_argument("--run-id",         default=None)
    ei.add_argument("--workload-id",    default=None)
    epr = eps.add_parser("project")
    epr.add_argument("--in",  dest="infile",  required=True)
    epr.add_argument("--out", dest="outfile", required=True)
    epr.add_argument("--attack-path-id", default="container_escape_privileged_v1")
    el = eps.add_parser("latest")
    el.add_argument("--interp",         required=True)
    el.add_argument("--attack-path-id", required=True)
    el.add_argument("--workload-id",    default=None)

    # lateral
    lp  = sub.add_parser("lateral")
    lps = lp.add_subparsers(dest="lateral_cmd", required=True)
    lps.add_parser("paths")
    li  = lps.add_parser("ingest")
    lis = li.add_subparsers(dest="lateral_adapter", required=True)
    lb  = lis.add_parser("bloodhound")
    lb.add_argument("--bh-dir",         required=True, dest="bh_dir")
    lb.add_argument("--out",            required=True)
    lb.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lb.add_argument("--run-id",         default=None)
    lb.add_argument("--workload-id",    default=None)
    ll = lis.add_parser("ldapdomaindump")
    ll.add_argument("--dump-dir",       required=True, dest="dump_dir")
    ll.add_argument("--out",            required=True)
    ll.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    ll.add_argument("--run-id",         default=None)
    ll.add_argument("--workload-id",    default=None)
    lm = lis.add_parser("manual")
    lm.add_argument("--input",          required=True)
    lm.add_argument("--out",            required=True)
    lm.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lm.add_argument("--run-id",         default=None)
    lm.add_argument("--workload-id",    default=None)
    lpr = lps.add_parser("project")
    lpr.add_argument("--in",  dest="infile",  required=True)
    lpr.add_argument("--out", dest="outfile", required=True)
    lpr.add_argument("--attack-path-id", required=True)
    ll2 = lps.add_parser("latest")
    ll2.add_argument("--interp",         required=True)
    ll2.add_argument("--attack-path-id", required=True)
    ll2.add_argument("--workload-id",    default=None)

    a = p.parse_args()
    dispatch = {
        "status":    cmd_status,
        "mode":      cmd_mode,
        "identity":  cmd_identity,
        "resonance": cmd_resonance,
        "aprs":      cmd_aprs,
        "escape":    cmd_escape,
        "lateral":   cmd_lateral,
        "field":     cmd_field,
    }
    dispatch.get(a.command, lambda _: p.print_help())(a)


if __name__ == "__main__":
    main()
