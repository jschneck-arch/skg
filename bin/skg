def cmd_lateral(a):
    subcmd = a.lateral_cmd
    if subcmd == "paths":
        sys.exit(_lateral("paths"))
    elif subcmd == "ingest":
        adapter = a.lateral_adapter
        args = ["ingest", adapter, "--out", a.out,
                "--attack-path-id", a.attack_path_id]
        if getattr(a, "run_id",      None): args += ["--run-id",      a.run_id]
        if getattr(a, "workload_id", None): args += ["--workload-id", a.workload_id]
        if adapter == "bloodhound":
            args += ["--bh-dir",   a.bh_dir]
        elif adapter == "ldapdomaindump":
            args += ["--dump-dir", a.dump_dir]
        elif adapter == "manual":
            args += ["--input",    a.input]
        sys.exit(_lateral(*args))
    elif subcmd == "project":
        sys.exit(_lateral("project",
                          "--in", a.infile, "--out", a.outfile,
                          "--attack-path-id", a.attack_path_id))
    elif subcmd == "latest":
        args = ["latest", "--interp", a.interp, "--attack-path-id", a.attack_path_id]
        if a.workload_id: args += ["--workload-id", a.workload_id]
        sys.exit(_lateral(*args))


# ---------------------------------------------------------------------------
# Host collection
# ---------------------------------------------------------------------------

def cmd_host(a):
    subcmd = a.host_cmd
    if subcmd == "paths":
        sys.exit(_host("paths"))
    elif subcmd == "latest":
        args = ["latest", "--interp", a.interp, "--attack-path-id", a.attack_path_id]
        if getattr(a, "workload_id", None): args += ["--workload-id", a.workload_id]
        sys.exit(_host(*args))
    elif subcmd == "project":
        args = ["project", "--in", a.infile, "--out", a.outfile,
                "--attack-path-id", a.attack_path_id]
        if getattr(a, "run_id",      None): args += ["--run-id",      a.run_id]
        if getattr(a, "workload_id", None): args += ["--workload-id", a.workload_id]
        sys.exit(_host(*args))
    elif subcmd == "ingest":
        adapter = a.host_adapter
        args = ["ingest", adapter, "--out", a.out, "--attack-path-id", a.attack_path_id]
        if getattr(a, "run_id",      None): args += ["--run-id",      a.run_id]
        if getattr(a, "workload_id", None): args += ["--workload-id", a.workload_id]
        if adapter == "ssh":
            args += ["--host", a.host, "--user", a.user, "--port", str(a.port)]
            if getattr(a, "key",      None): args += ["--key",      a.key]
            if getattr(a, "password", None): args += ["--password", a.password]
            if getattr(a, "timeout",  None): args += ["--timeout",  str(a.timeout)]
        elif adapter == "winrm":
            args += ["--host", a.host, "--user", a.user, "--password", a.password,
                     "--port", str(a.port)]
            if getattr(a, "ssl", False): args += ["--ssl"]
        elif adapter == "nmap":
            if getattr(a, "xml",    None): args += ["--xml",    a.xml]
            if getattr(a, "target", None): args += ["--target", a.target]
            if getattr(a, "ports",  None): args += ["--ports",  a.ports]
            if getattr(a, "nmap_flags", None): args += ["--nmap-flags", a.nmap_flags]
        elif adapter == "msf_session":
            if getattr(a, "rpc_host",  None): args += ["--rpc-host",   a.rpc_host]
            if getattr(a, "json_dump", None): args += ["--json-dump",  a.json_dump]
            args += ["--rpc-port", str(a.rpc_port), "--rpc-password", a.rpc_password]
            if getattr(a, "rpc_ssl", False): args += ["--rpc-ssl"]
        sys.exit(_host(*args))


def cmd_collect(a):
    """POST /collect to the daemon — trigger a collection sweep."""
    data = {}
    if getattr(a, "target", None):
        data["target"] = a.target
        data["method"] = getattr(a, "method", "ssh")
        if getattr(a, "user",           None): data["user"]           = a.user
        if getattr(a, "password",       None): data["password"]       = a.password
        if getattr(a, "key",            None): data["key"]            = a.key
        if getattr(a, "port",           None): data["port"]           = a.port
        if getattr(a, "workload_id",    None): data["workload_id"]    = a.workload_id
        if getattr(a, "attack_path_id", None): data["attack_path_id"] = a.attack_path_id
        if getattr(a, "auto_project",   False): data["auto_project"]  = True
    r = _api("POST", "/collect", data if data else None)
    print(f"  run_id : {r.get('run_id', '?')}")
    print(f"  ok     : {r.get('ok', '?')}")
    if r.get("target"):
        print(f"  target : {r['target']}")
    if r.get("events_file"):
        print(f"  events : {r['events_file']}")
    if r.get("interp_file"):
        print(f"  interp : {r['interp_file']}")


# ---------------------------------------------------------------------------
# Parser
# ---------------------------------------------------------------------------

def main():
    p   = argparse.ArgumentParser(prog="skg",
              description="SKG — Semantic Kernel Gravity")
    sub = p.add_subparsers(dest="command")

    # daemon
    sub.add_parser("status")

    mp = sub.add_parser("mode")
    mp.add_argument("set_mode", nargs="?",
                    choices=["kernel","resonance","unified","anchor"])
    mp.add_argument("--reason", default="")

    ip = sub.add_parser("identity")
    ip.add_argument("subcommand", nargs="?", choices=["history"])

    # resonance
    rp  = sub.add_parser("resonance")
    rps = rp.add_subparsers(dest="resonance_cmd", required=True)
    rps.add_parser("status")
    rps.add_parser("ingest")
    rq = rps.add_parser("query")
    rq.add_argument("text")
    rq.add_argument("--type", default="all",
                    choices=["all","wickets","adapters","domains"])
    rq.add_argument("--k", type=int, default=5)
    rdp = rps.add_parser("draft-prompt")
    rdp.add_argument("domain")
    rdp.add_argument("description")

    rda = rps.add_parser("draft-accept")
    rda.add_argument("domain")
    rda.add_argument("response", help="Path to JSON file, raw JSON string, or - for stdin")

    rps.add_parser("drafts")

    rdg = rps.add_parser("draft-generate",
                          help="Generate catalog via local ollama (no API key needed)")
    rdg.add_argument("domain")
    rdg.add_argument("description")

    rps.add_parser("ollama", help="Check ollama backend status")

    # train
    trp = sub.add_parser("train", help="Training corpus and fine-tune pipeline")
    trs = trp.add_subparsers(dest="train_cmd", required=True)
    trs.add_parser("status", help="Training system status")
    trr = trs.add_parser("run", help="Trigger fine-tune run")
    trr.add_argument("--wait",  action="store_true", help="Block until complete")
    trr.add_argument("--force", action="store_true", help="Ignore readiness checks")
    trc = trs.add_parser("corpus", help="Corpus management")
    trcs = trc.add_subparsers(dest="corpus_cmd")
    trcl = trcs.add_parser("list", help="List examples")
    trcl.add_argument("--label", choices=["positive","negative"], default=None)
    trcl.add_argument("--kind",  choices=["catalog","adapter","wicket_map"], default=None)
    trca = trcs.add_parser("add", help="Manually add a positive example")
    trca.add_argument("kind",        choices=["catalog","adapter","wicket_map"])
    trca.add_argument("domain")
    trca.add_argument("input_file",  help="File containing prompt/input")
    trca.add_argument("output_file", help="File containing expected output")
    trcs.add_parser("clear", help="Clear all corpus examples")
    trs.add_parser("install-unsloth", help="Install unsloth fine-tuning library")
    trs.add_parser("rollback",        help="Rollback to previous model")

    # surface
    sfp = sub.add_parser("surface", help="Engagement surface summary")
    sfs = sfp.add_subparsers(dest="surface_cmd")
    sfr = sfs.add_parser("report", help="Full engagement report (default)")
    sfr.add_argument("--verbose", "-v", action="store_true")
    sfj = sfs.add_parser("json",    help="Full report as JSON")
    sfg = sfs.add_parser("gaps",    help="Coverage gap list")
    sfw = sfs.add_parser("workloads", help="Per-workload projection state")
    sfw.add_argument("--verbose", "-v", action="store_true")
    sfp.set_defaults(surface_cmd="report")

    # proposals
    prp = sub.add_parser("proposals", help="Toolchain proposal queue")
    prs = prp.add_subparsers(dest="proposals_cmd", required=True)
    prl = prs.add_parser("list",   help="List pending proposals")
    prl.add_argument("--status",  default="pending",
                     choices=["pending","accepted","rejected","all"])
    prl.add_argument("--verbose", "-v", action="store_true")
    prsh = prs.add_parser("show",   help="Show proposal detail")
    prsh.add_argument("id")
    prac = prs.add_parser("accept", help="Accept and install toolchain")
    prac.add_argument("id")
    prre = prs.add_parser("reject", help="Reject with cooldown")
    prre.add_argument("id")
    prre.add_argument("--reason", default="")
    prde = prs.add_parser("defer",  help="Defer proposal")
    prde.add_argument("id")
    prde.add_argument("--days", type=int, default=7)

    # forge
    fgp = sub.add_parser("forge", help="Toolchain generation")
    fgs = fgp.add_subparsers(dest="forge_cmd", required=True)
    fgg = fgs.add_parser("generate", help="Generate toolchain for a domain")
    fgg.add_argument("domain")
    fgg.add_argument("--description", default=None)
    fgg.add_argument("--hosts", default="",
                     help="Comma-separated host list for context")
    fgg.add_argument("--force", action="store_true",
                     help="Regenerate even if staging dir exists")
    fgg.add_argument("--no-propose", action="store_true",
                     help="Generate without creating a proposal")
    fgs.add_parser("list-staged", help="List staged (uninstalled) toolchains")
    fgs.add_parser("pipeline",    help="Manually run gap detection + generation pipeline")

    # aprs
    ap  = sub.add_parser("aprs")
    aps = ap.add_subparsers(dest="aprs_cmd", required=True)
    aps.add_parser("paths")
    ai = aps.add_parser("ingest")
    ai.add_argument("adapter", choices=["config_effective","net_sandbox"])
    ai.add_argument("--out",            required=True)
    ai.add_argument("--attack-path-id", default="log4j_jndi_rce_v1")
    ai.add_argument("--run-id",         default=None)
    ai.add_argument("--workload-id",    default=None)
    ai.add_argument("--root",           default=None)
    ai.add_argument("--docker-inspect", dest="docker_inspect", default=None)
    ai.add_argument("--resolv-conf",    dest="resolv_conf",    default=None)
    ai.add_argument("--iptables",       default=None)
    ai.add_argument("--ps",             default=None)
    apr = aps.add_parser("project")
    apr.add_argument("--in",  dest="infile",  required=True)
    apr.add_argument("--out", dest="outfile", required=True)
    apr.add_argument("--attack-path-id", default="log4j_jndi_rce_v1")
    al = aps.add_parser("latest")
    al.add_argument("--interp",         required=True)
    al.add_argument("--attack-path-id", required=True)
    al.add_argument("--workload-id",    default=None)

    # escape
    ep  = sub.add_parser("escape")
    eps = ep.add_subparsers(dest="escape_cmd", required=True)
    eps.add_parser("paths")
    ei = eps.add_parser("ingest")
    ei.add_argument("--inspect",        required=True)
    ei.add_argument("--out",            required=True)
    ei.add_argument("--attack-path-id", default="container_escape_privileged_v1")
    ei.add_argument("--run-id",         default=None)
    ei.add_argument("--workload-id",    default=None)
    epr = eps.add_parser("project")
    epr.add_argument("--in",  dest="infile",  required=True)
    epr.add_argument("--out", dest="outfile", required=True)
    epr.add_argument("--attack-path-id", default="container_escape_privileged_v1")
    el = eps.add_parser("latest")
    el.add_argument("--interp",         required=True)
    el.add_argument("--attack-path-id", required=True)
    el.add_argument("--workload-id",    default=None)

    # lateral
    lp  = sub.add_parser("lateral")
    lps = lp.add_subparsers(dest="lateral_cmd", required=True)
    lps.add_parser("paths")
    li  = lps.add_parser("ingest")
    lis = li.add_subparsers(dest="lateral_adapter", required=True)
    lb  = lis.add_parser("bloodhound")
    lb.add_argument("--bh-dir",         required=True, dest="bh_dir")
    lb.add_argument("--out",            required=True)
    lb.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lb.add_argument("--run-id",         default=None)
    lb.add_argument("--workload-id",    default=None)
    ll = lis.add_parser("ldapdomaindump")
    ll.add_argument("--dump-dir",       required=True, dest="dump_dir")
    ll.add_argument("--out",            required=True)
    ll.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    ll.add_argument("--run-id",         default=None)
    ll.add_argument("--workload-id",    default=None)
    lm = lis.add_parser("manual")
    lm.add_argument("--input",          required=True)
    lm.add_argument("--out",            required=True)
    lm.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lm.add_argument("--run-id",         default=None)
    lm.add_argument("--workload-id",    default=None)
    lpr = lps.add_parser("project")
    lpr.add_argument("--in",  dest="infile",  required=True)
    lpr.add_argument("--out", dest="outfile", required=True)
    lpr.add_argument("--attack-path-id", required=True)
    ll2 = lps.add_parser("latest")
    ll2.add_argument("--interp",         required=True)
    ll2.add_argument("--attack-path-id", required=True)
    ll2.add_argument("--workload-id",    default=None)

    # host
    hp  = sub.add_parser("host")
    hps = hp.add_subparsers(dest="host_cmd", required=True)
    hps.add_parser("paths")
    hhi = hps.add_parser("ingest")
    hhs = hhi.add_subparsers(dest="host_adapter", required=True)

    # host ingest ssh
    hs = hhs.add_parser("ssh")
    hs.add_argument("--host",           required=True)
    hs.add_argument("--user",           required=True)
    hs.add_argument("--key",            default=None)
    hs.add_argument("--password",       default=None)
    hs.add_argument("--port",           type=int, default=22)
    hs.add_argument("--timeout",        type=int, default=15)
    hs.add_argument("--out",            required=True)
    hs.add_argument("--attack-path-id", default="host_ssh_initial_access_v1")
    hs.add_argument("--run-id",         default=None)
    hs.add_argument("--workload-id",    default=None)

    # host ingest winrm
    hw = hhs.add_parser("winrm")
    hw.add_argument("--host",           required=True)
    hw.add_argument("--user",           required=True)
    hw.add_argument("--password",       required=True)
    hw.add_argument("--port",           type=int, default=5985)
    hw.add_argument("--ssl",            action="store_true", default=False)
    hw.add_argument("--out",            required=True)
    hw.add_argument("--attack-path-id", default="host_winrm_initial_access_v1")
    hw.add_argument("--run-id",         default=None)
    hw.add_argument("--workload-id",    default=None)

    # host ingest nmap
    hn = hhs.add_parser("nmap")
    hn_grp = hn.add_mutually_exclusive_group(required=True)
    hn_grp.add_argument("--xml",    default=None)
    hn_grp.add_argument("--target", default=None)
    hn.add_argument("--ports",          default=None)
    hn.add_argument("--nmap-flags",     dest="nmap_flags", default=None)
    hn.add_argument("--out",            required=True)
    hn.add_argument("--attack-path-id", default="host_network_exploit_v1")
    hn.add_argument("--run-id",         default=None)
    hn.add_argument("--workload-id",    default=None)

    # host ingest msf_session
    hm = hhs.add_parser("msf_session")
    hm_grp = hm.add_mutually_exclusive_group(required=True)
    hm_grp.add_argument("--rpc-host",   dest="rpc_host",  default=None)
    hm_grp.add_argument("--json-dump",  dest="json_dump", default=None)
    hm.add_argument("--rpc-port",       dest="rpc_port",  type=int, default=55553)
    hm.add_argument("--rpc-password",   dest="rpc_password", default="msf")
    hm.add_argument("--rpc-ssl",        dest="rpc_ssl",   action="store_true", default=False)
    hm.add_argument("--out",            required=True)
    hm.add_argument("--attack-path-id", default="host_msf_post_exploitation_v1")
    hm.add_argument("--run-id",         default=None)
    hm.add_argument("--workload-id",    default="msf_workspace")

    # host project / latest
    hpr = hps.add_parser("project")
    hpr.add_argument("--in",  dest="infile",  required=True)
    hpr.add_argument("--out", dest="outfile", required=True)
    hpr.add_argument("--attack-path-id", default="host_ssh_initial_access_v1")
    hpr.add_argument("--run-id",         default=None)
    hpr.add_argument("--workload-id",    default=None)
    hla = hps.add_parser("latest")
    hla.add_argument("--interp",         required=True)
    hla.add_argument("--attack-path-id", required=True)
    hla.add_argument("--workload-id",    default=None)

    # collect (daemon-driven)
    cp = sub.add_parser("collect")
    cp.add_argument("--target",           default=None)
    cp.add_argument("--method",           default="ssh", choices=["ssh","winrm","nmap"])
    cp.add_argument("--user",             default=None)
    cp.add_argument("--password",         default=None)
    cp.add_argument("--key",              default=None)
    cp.add_argument("--port",             type=int, default=22)
    cp.add_argument("--workload-id",      dest="workload_id",    default=None)
    cp.add_argument("--attack-path-id",   dest="attack_path_id", default="host_ssh_initial_access_v1")
    cp.add_argument("--auto-project",     dest="auto_project",   action="store_true", default=False)

    # catalog subcommand
    catp = sub.add_parser("catalog", help="YAML catalog authoring tools")
    cat_subs = catp.add_subparsers(dest="catalog_cmd", required=True)
    cc = cat_subs.add_parser("compile",  help="Compile YAML → JSON")
    cc.add_argument("yaml_file")
    cc.add_argument("--out", default=None, help="Output directory")
    cv = cat_subs.add_parser("validate", help="Validate YAML catalog")
    cv.add_argument("yaml_file")
    cs = cat_subs.add_parser("scaffold", help="Generate YAML template")
    cs.add_argument("domain")
    cs.add_argument("--out", default=None)
    cl = cat_subs.add_parser("lint",     help="Lint existing catalog JSON")
    cl.add_argument("catalog_json")

    # sensors status subcommand
    sp = sub.add_parser("sensors", help="Sensor status and control")
    sp.add_argument("sensor_cmd", nargs="?", choices=["status", "trigger"], default="status")

    a = p.parse_args()

    def cmd_catalog(a):
        sys.path.insert(0, str(SKG_HOME))
        from skg.catalog.compiler import main as cat_main
        argv = [a.catalog_cmd]
        if a.catalog_cmd == "compile":
            argv += [a.yaml_file]
            if a.out: argv += ["--out", a.out]
        elif a.catalog_cmd == "validate":
            argv += [a.yaml_file]
        elif a.catalog_cmd == "scaffold":
            argv += [a.domain]
            if a.out: argv += ["--out", a.out]
        elif a.catalog_cmd == "lint":
            argv += [a.catalog_json]
        cat_main(argv)

    def cmd_sensors(a):
        cmd = getattr(a, "sensor_cmd", "status")
        if cmd == "trigger":
            d = _api("POST", "/sensors/trigger")
            print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")
        else:
            d = _api("GET", "/sensors")
            print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")

    # feedback subcommand
    fbp = sub.add_parser("feedback", help="Temporal delta, workload graph, observation memory")
    fb_subs = fbp.add_subparsers(dest="feedback_cmd", required=True)
    fb_subs.add_parser("status",  help="Show delta/graph/obs memory status")
    fb_subs.add_parser("process", help="Process unprocessed projection results")
    fb_surface = fb_subs.add_parser("surface", help="High-signal transitions across all workloads")
    fb_surface.add_argument("--min-weight", type=float, default=0.8, dest="min_weight")
    fb_timeline = fb_subs.add_parser("timeline", help="State history for a workload")
    fb_timeline.add_argument("workload_id")
    fb_timeline.add_argument("--path", default=None, dest="attack_path_id")
    fb_graph = fb_subs.add_parser("graph", help="Manage workload relationships")
    fb_graph_subs = fb_graph.add_subparsers(dest="graph_cmd", required=True)
    fb_graph_subs.add_parser("status")
    fb_ge = fb_graph_subs.add_parser("add-edge")
    fb_ge.add_argument("source")
    fb_ge.add_argument("target")
    fb_ge.add_argument("relationship",
        choices=["same_domain","same_subnet","trust_relationship","credential_overlap","network_adjacent"])
    fb_graph_subs.add_parser("workloads")

    def cmd_feedback(a):
        cmd = a.feedback_cmd
        if cmd == "status":
            d = _api("GET", "/feedback/status")
            print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")
        elif cmd == "process":
            d = _api("POST", "/feedback/process")
            print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")
        elif cmd == "surface":
            d = _api("GET", f"/feedback/surface?min_weight={a.min_weight}")
            print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")
        elif cmd == "timeline":
            url = f"/feedback/timeline/{a.workload_id}"
            if a.attack_path_id:
                url += f"?attack_path_id={a.attack_path_id}"
            d = _api("GET", url)
            print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")
        elif cmd == "graph":
            gc = a.graph_cmd
            if gc == "status":
                d = _api("GET", "/graph/status")
                print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")
            elif gc == "add-edge":
                d = _api("POST", f"/graph/edge?source={a.source}&target={a.target}&relationship={a.relationship}")
                print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")
            elif gc == "workloads":
                d = _api("GET", "/delta/workloads")
                print(json.dumps(d, indent=2) if d else "✗ daemon unreachable")

    dispatch = {
        "status":    cmd_status,
        "mode":      cmd_mode,
        "identity":  cmd_identity,
        "resonance": cmd_resonance,
        "surface":   cmd_surface,
        "proposals": cmd_proposals,
        "forge":     cmd_forge,
        "aprs":      cmd_aprs,
        "escape":    cmd_escape,
        "lateral":   cmd_lateral,
        "host":      cmd_host,
        "collect":   cmd_collect,
        "catalog":   cmd_catalog,
        "sensors":   cmd_sensors,
        "feedback":  cmd_feedback,
        "train":     cmd_train,
    }
    dispatch.get(a.command, lambda _: p.print_help())(a)


if __name__ == "__main__":
    main()
