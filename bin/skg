#!/usr/bin/env python3
"""
skg — Unified CLI for Spherical Knowledge Graph

FIELD (gravity state):
  skg start                              start the gravity field
  skg stop                               stop the gravity field
  skg status                             entropy landscape + instrument states
  skg surface                            full attack surface (all projections)
  skg web                                gravity web (bonds + coupling)
  skg field <workload> [domain]          raw field state for a workload

TOPOLOGY:
  skg target add <ip> [--domain X]       add mass to the field
  skg target add-subnet <cidr> [--deep]  discover subnet, add targets
  skg target remove <ip>                 remove mass from the field
  skg target list                        all targets with entropy
  skg target link <ip1> <ip2> <type>     assert a bond
  skg target edges                       all bonds in the gravity web

OBSERVATION:
  skg observe <ip>                       trigger best instrument for target
  skg observe <ip> --with ssh            specify instrument
  skg observe <ip> --with web            unauthenticated web scan
  skg observe <ip> --with web --auth     authenticated web scan
  skg observe <ip> --with nmap           nmap version detection + NSE

GRAVITY:
  skg gravity [--cycles N]               run gravity loop (default: auto from daemon)

MODES:
  skg mode [kernel|resonance|unified|anchor] [--reason "..."]

INTELLIGENCE:
  skg feed nvd                           enrich field with NVD CVE data
  skg feed nvd --service "Apache/2.4.25" targeted CVE lookup

RESONANCE:
  skg resonance status|ingest|query|draft|drafts

IDENTITY:
  skg identity [history]

TOOLCHAINS (direct):
  skg aprs    ingest|project|latest|paths
  skg escape  ingest|project|latest|paths
  skg lateral ingest|project|latest|paths
  skg catalog compile [options]
"""

import sys, argparse
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from skg.core.paths import SKG_STATE_DIR

# ── Migrated command modules ──────────────────────────────────────────────
from skg.cli.commands.system      import cmd_start, cmd_stop, cmd_status, cmd_mode, cmd_identity
from skg.cli.commands.surface     import cmd_surface, cmd_web_view, cmd_folds, cmd_field
from skg.cli.commands.target      import cmd_target, cmd_observe
from skg.cli.commands.proposals   import cmd_proposals
from skg.cli.commands.report      import cmd_report, cmd_calibrate, cmd_engage
from skg.cli.commands.gravity     import cmd_gravity
from skg.cli.commands.exploit     import cmd_exploit, cmd_audit, cmd_collect
from skg.cli.commands.intelligence import cmd_feed, cmd_graph, cmd_resonance
from skg.cli.commands.toolchains  import cmd_aprs, cmd_escape, cmd_lateral, cmd_catalog
from skg.cli.commands.derived     import cmd_derived
from skg.cli.commands.data        import cmd_data
from skg.cli.commands.check       import cmd_check
from skg.cli.commands.replay      import cmd_replay


def main():
    p = argparse.ArgumentParser(prog="skg",
            description="SKG — Spherical Knowledge Graph")
    sub = p.add_subparsers(dest="command")

    # ── Field
    sub.add_parser("start", help="start the gravity field")
    sub.add_parser("stop", help="stop the gravity field")
    sp = sub.add_parser("status", help="entropy landscape + field state")
    sp.add_argument("--self-audit", action="store_true",
                    help="audit SKG substrate health: memory, folds, proposals, recall, feedback, local model")
    sub.add_parser("surface", help="full attack surface map")

    wp = sub.add_parser("web", help="gravity web — bonds + coupling")

    # ── Topology
    tp = sub.add_parser("target", help="topology management")
    tps = tp.add_subparsers(dest="target_cmd", required=True)

    ta = tps.add_parser("add", help="add mass to the field")
    ta.add_argument("ip")
    ta.add_argument("--domain", default=None)

    tas = tps.add_parser("add-subnet", help="discover subnet, add targets")
    tas.add_argument("cidr")
    tas.add_argument("--deep", action="store_true")

    tr = tps.add_parser("remove", help="remove mass from the field")
    tr.add_argument("ip")

    tps.add_parser("list", help="all targets with entropy")

    tl = tps.add_parser("link", help="assert a bond")
    tl.add_argument("ip1")
    tl.add_argument("ip2")
    tl.add_argument("bond_type")

    tps.add_parser("edges", help="all bonds in the gravity web")

    # ── Startup validation
    sub.add_parser("check", help="validate required tools and configuration")

    # ── Replay pre-recorded events
    rp = sub.add_parser("replay", help="replay recorded events and show field state")
    rp.add_argument("events_dir", help="directory containing .ndjson event files")

    # ── Observation
    op = sub.add_parser("observe", help="trigger observation on a target")
    op.add_argument("ip")
    op.add_argument("--with", dest="instrument", default=None,
                    choices=["web", "ssh", "nmap", "msf", "pcap"])
    op.add_argument("--auth", action="store_true",
                    help="authenticated scan (for --with web)")

    # ── Proposals
    pp = sub.add_parser("proposals", help="operator proposal queue")
    pps = pp.add_subparsers(dest="proposal_cmd", required=True)
    ppl = pps.add_parser("list", help="list proposals")
    ppl.add_argument("--status", default="all")
    pps.add_parser("show", help="show proposal").add_argument("proposal_id")
    pt_trig = pps.add_parser("trigger", help="trigger field_action proposal")
    pt_trig.add_argument("proposal_id")
    pt_trig.add_argument("--await-session", action="store_true",
                         help="detect open MSF session and run post-exploitation collection")
    pps.add_parser("accept", help="accept toolchain proposal").add_argument("proposal_id")
    prj = pps.add_parser("reject", help="reject proposal")
    prj.add_argument("proposal_id")
    prj.add_argument("--reason", default="")
    pdf = pps.add_parser("defer", help="defer proposal")
    pdf.add_argument("proposal_id")
    pdf.add_argument("days", nargs="?", type=int, default=7)

    # ── Data pipeline
    dp = sub.add_parser("data", help="data pipeline integrity — DP-01..DP-15 wickets")
    dps = dp.add_subparsers(dest="data_cmd", required=False)

    dpp = dps.add_parser("profile", help="profile a database table against a contract")
    dpp.add_argument("--url",      required=True,  help="SQLAlchemy DB URL")
    dpp.add_argument("--table",    required=True,  help="table or view to profile")
    dpp.add_argument("--workload-id", dest="workload_id", default=None)
    dpp.add_argument("--contract", default=None,   help="schema contract JSON")
    dpp.add_argument("--attack-path-id", dest="attack_path_id",
                     default="data_completeness_failure_v1")
    dpp.add_argument("--out",      default=None)

    dpj = dps.add_parser("project", help="project DP-* events against a failure path")
    dpj.add_argument("--in",  dest="infile",  required=True)
    dpj.add_argument("--path-id", dest="path_id", required=True)

    dps.add_parser("paths",   help="list all data failure paths")
    dps.add_parser("catalog", help="print the full data catalog JSON")

    disc = dps.add_parser("discover",
        help="SSH-discover DB services and run combined DE-* + DP-* assessment")
    disc.add_argument("--host",     required=True, help="target IP or hostname")
    disc.add_argument("--user",     required=True, help="SSH username")
    disc.add_argument("--password", default=None,  help="SSH password")
    disc.add_argument("--key",      default=None,  help="SSH key file")
    disc.add_argument("--ssh-port", dest="ssh_port", type=int, default=22)
    disc.add_argument("--workload-id", dest="workload_id", default=None)
    disc.add_argument("--tables",   default=None,
                      help="comma-separated list of tables to profile (default: auto)")
    disc.add_argument("--out-dir",  dest="out_dir", default=None)

    # ── Collect (direct host collection)
    cp2 = sub.add_parser("collect", help="collect from a specific host")
    cp2.add_argument("--target", required=True, help="target IP or hostname")
    cp2.add_argument("--method", default="ssh", choices=["ssh", "winrm"])
    cp2.add_argument("--user", default=None)
    cp2.add_argument("--key", default=None)
    cp2.add_argument("--port", type=int, default=22)
    cp2.add_argument("--auto-project", dest="auto_project", action="store_true")

    # ── Gravity
    gp = sub.add_parser("gravity", help="run the gravity field loop")
    gp.add_argument("--cycles", type=int, default=5)
    gp.add_argument("--target", default=None)
    gp.add_argument("--authorized", action="store_true",
                    help="Authorized engagement: auto-execute exploit proposals without operator trigger")

    # ── Derived state
    dd = sub.add_parser("derived", help="archive or rebuild derived operator state")
    dds = dd.add_subparsers(dest="derived_cmd", required=True)
    dds.add_parser("archive", help="archive derived interp/fold state and recreate empty directories")
    ddr = dds.add_parser("rebuild", help="rebuild derived interp/fold state from append-only substrate")
    ddr.add_argument("--append", action="store_true", help="append rebuild output into existing derived directories")

    # ── Report
    rp2 = sub.add_parser("report", help="substrate report from canonical state")
    rp2.add_argument("--target", default=None, help="scope report to one target in surface")
    rp2.add_argument("--at", default=None, help="show target state as of an ISO timestamp from pearls")
    rp2.add_argument("--diff-against", dest="diff_against", default=None, help="diff current target state against an ISO timestamp from pearls")
    rp2.add_argument("--json", dest="json_out", action="store_true", help="emit raw JSON report")
    rp2.add_argument("--llm", action="store_true", help="ask TinyLlama for a short narrative summary")

    # ── Mode
    mp = sub.add_parser("mode", help="set operational mode")
    mp.add_argument("set_mode", nargs="?",
                    choices=["kernel", "resonance", "unified", "anchor"])
    mp.add_argument("--reason", default="")

    # ── Confidence calibration
    cal_p = sub.add_parser("calibrate",
        help="learn per-sensor confidence weights from engagement history")
    cal_p.add_argument("--db", default=str(SKG_STATE_DIR / "engagement.db"),
                        help="engagement database (build with: skg engage build)")
    cal_p.add_argument("--report", action="store_true",
                        help="print calibration report without saving")

    # ── Engagement dataset
    enp = sub.add_parser("engage",
        help="engagement dataset — build DB from telemetry + analyze integrity")
    ens = enp.add_subparsers(dest="engage_cmd", required=False)

    en_build = ens.add_parser("build", help="build SQLite DB from all telemetry")
    en_build.add_argument("--out", default=str(SKG_STATE_DIR / "engagement.db"))

    en_analyze = ens.add_parser("analyze", help="analyze dataset integrity (DP-* checks)")
    en_analyze.add_argument("--db", default=str(SKG_STATE_DIR / "engagement.db"))

    en_report = ens.add_parser("report", help="full engagement report")
    en_report.add_argument("--db",  default=str(SKG_STATE_DIR / "engagement.db"))
    en_report.add_argument("--out", default=None, help="write JSON report to file")

    en_clean = ens.add_parser("clean",
        help="repair DP-03/04/05 violations (null fields, out-of-bounds values, orphans)")
    en_clean.add_argument("--db", default=str(SKG_STATE_DIR / "engagement.db"))

    # ── System audit (filesystem / process / log integrity)
    aup = sub.add_parser("audit", help="system integrity — FI/PI/LI wickets")
    aus = aup.add_subparsers(dest="audit_cmd", required=False)

    aus_scan = aus.add_parser("scan", help="audit a host via SSH")
    aus_scan.add_argument("--target",      required=True)
    aus_scan.add_argument("--user",        default=None)
    aus_scan.add_argument("--key",         default=None)
    aus_scan.add_argument("--password",    default=None)
    aus_scan.add_argument("--workload-id", dest="workload_id", default=None)
    aus_scan.add_argument("--attack-path-id", dest="attack_path_id",
                          default="full_system_integrity_v1")
    aus_scan.add_argument("--checks", default=None,
                          help="comma-separated check IDs e.g. fi01,pi02,li05")

    aus_proj = aus.add_parser("project", help="project FI/PI/LI events against a path")
    aus_proj.add_argument("--in",      dest="infile",  required=True)
    aus_proj.add_argument("--path-id", dest="path_id", required=True)

    aus.add_parser("paths", help="list system integrity failure paths")

    # ── Exploit dispatch
    xp = sub.add_parser("exploit", help="translate realized paths into MSF proposals + binary analysis")
    xps = xp.add_subparsers(dest="exploit_cmd", required=False)

    xpe = xps.add_parser("propose", help="generate exploit proposals for a realized path")
    xpe.add_argument("--path-id",   required=True,  help="attack path ID (e.g. web_sqli_to_shell_v1)")
    xpe.add_argument("--target",    required=True,  help="target IP")
    xpe.add_argument("--port",      type=int, default=80)
    xpe.add_argument("--realized",  nargs="+", default=[], help="realized wicket IDs")
    xpe.add_argument("--lhost",     default="",  help="local host IP for reverse shells")
    xpe.add_argument("--session-id", dest="session_id", default="")

    xpv = xps.add_parser("privesc", help="post-session privesc chain proposals")
    xpv.add_argument("--session-id", dest="session_id", required=True)
    xpv.add_argument("--target",    required=True)
    xpv.add_argument("--known",     nargs="+", default=[], help="already-known wicket IDs")

    xpb = xps.add_parser("binary", help="analyze binary for BA-* wickets (NX, canary, overflow path)")
    xpb.add_argument("binary_path")
    xpb.add_argument("--workload-id", dest="workload_id", default="")

    xps.add_parser("list-paths", help="list all mapped exploit paths")
    xps.add_parser("binary-catalog", help="print binary analysis catalog JSON")

    xcr = xps.add_parser("cred-reuse", help="test stored credentials against a target's services")
    xcr.add_argument("--target", required=True, help="target IP or hostname")
    xcr.add_argument("--authorized", action="store_true",
                     help="Test credentials directly (authorized engagement; default: generate proposals)")

    # ── Wicket graph
    grp = sub.add_parser("graph",
        help="wicket knowledge graph — Kuramoto K-topology, entanglement, phase gradient")
    grs = grp.add_subparsers(dest="graph_cmd", required=False)
    grs.add_parser("topology", help="global R, cluster R, entangled pairs, top gradient signals")
    gre = grs.add_parser("edges", help="neighbors, K values, and phase for a wicket")
    gre.add_argument("wicket_id", help="e.g. HO-04")
    grs.add_parser("entangled",   help="all non-separable pairs (K ≥ 0.80)")
    grs.add_parser("hypotheses",  help="predicted wickets: observable vs dark (no instrument)")

    # ── Folds
    flp = sub.add_parser("folds", help="structural knowledge gaps that add to field energy")
    fls = flp.add_subparsers(dest="folds_cmd", required=False)
    fls.add_parser("list",       help="all active folds")
    fls.add_parser("structural", help="services with no toolchain (dark attack surface)")
    flr = fls.add_parser("resolve", help="mark fold as resolved after toolchain/mapping created")
    flr.add_argument("fold_id")
    flr.add_argument("--target", required=True, help="target IP")

    # ── Feed
    fdp = sub.add_parser("feed", help="intelligence feeds")
    fds = fdp.add_subparsers(dest="feed_cmd", required=True)
    fn = fds.add_parser("nvd", help="NVD CVE lookup")
    fn.add_argument("--service", default=None, help="specific service to look up")

    # ── Resonance
    rp = sub.add_parser("resonance", help="semantic memory + catalog expansion")
    rps = rp.add_subparsers(dest="resonance_cmd", required=True)
    rps.add_parser("status")
    rps.add_parser("ingest")
    rps.add_parser("ollama")
    rq = rps.add_parser("query")
    rq.add_argument("text")
    rq.add_argument("--type", default="all",
                    choices=["all", "wickets", "adapters", "domains"])
    rq.add_argument("--k", type=int, default=5)
    rd = rps.add_parser("draft")
    rd.add_argument("domain")
    rd.add_argument("description")
    rd.add_argument("--api-key", dest="api_key", default=None)
    rps.add_parser("drafts")

    # ── Identity
    idp = sub.add_parser("identity", help="who is SKG")
    idp.add_argument("subcommand", nargs="?", choices=["history"])

    # ── Field (per-workload)
    fp = sub.add_parser("field", help="per-workload field state")
    fp.add_argument("workload_id")
    fp.add_argument("domain", nargs="?", default="host",
                    choices=["host", "container_escape", "ad_lateral",
                             "aprs", "web", "supply_chain", "data"])

    # ── Catalog
    catp = sub.add_parser("catalog", help="catalog management")
    cats = catp.add_subparsers(dest="catalog_cmd", required=True)
    catc = cats.add_parser("compile")
    catc.add_argument("--domain", required=True)
    catc.add_argument("--description", required=True)
    catc.add_argument("--packages", default="")
    catc.add_argument("--keywords", default="")
    catc.add_argument("--prefix", default=None)
    catc.add_argument("--api-key", default=None)
    catc.add_argument("--min-cvss", type=float, default=6.0)
    catc.add_argument("--max-wickets", type=int, default=20)
    catc.add_argument("--out", default=None)
    catc.add_argument("--dry-run", action="store_true")

    # ── Toolchains
    ap = sub.add_parser("aprs")
    aps = ap.add_subparsers(dest="aprs_cmd", required=True)
    aps.add_parser("paths")
    ai = aps.add_parser("ingest")
    ai.add_argument("adapter", choices=["config_effective", "net_sandbox"])
    ai.add_argument("--out", required=True)
    ai.add_argument("--attack-path-id", default="log4j_jndi_rce_v1")
    ai.add_argument("--run-id", default=None)
    ai.add_argument("--workload-id", default=None)
    ai.add_argument("--root", default=None)
    ai.add_argument("--docker-inspect", dest="docker_inspect", default=None)
    ai.add_argument("--resolv-conf", dest="resolv_conf", default=None)
    ai.add_argument("--iptables", default=None)
    ai.add_argument("--ps", default=None)
    apr = aps.add_parser("project")
    apr.add_argument("--in", dest="infile", required=True)
    apr.add_argument("--out", dest="outfile", required=True)
    apr.add_argument("--attack-path-id", default="log4j_jndi_rce_v1")
    al = aps.add_parser("latest")
    al.add_argument("--interp", required=True)
    al.add_argument("--attack-path-id", required=True)
    al.add_argument("--workload-id", default=None)

    ep = sub.add_parser("escape")
    eps = ep.add_subparsers(dest="escape_cmd", required=True)
    eps.add_parser("paths")
    ei = eps.add_parser("ingest")
    ei.add_argument("--inspect", required=True)
    ei.add_argument("--out", required=True)
    ei.add_argument("--attack-path-id", default="container_escape_privileged_v1")
    ei.add_argument("--run-id", default=None)
    ei.add_argument("--workload-id", default=None)
    epr = eps.add_parser("project")
    epr.add_argument("--in", dest="infile", required=True)
    epr.add_argument("--out", dest="outfile", required=True)
    epr.add_argument("--attack-path-id", default="container_escape_privileged_v1")
    el = eps.add_parser("latest")
    el.add_argument("--interp", required=True)
    el.add_argument("--attack-path-id", required=True)
    el.add_argument("--workload-id", default=None)

    lp = sub.add_parser("lateral")
    lps = lp.add_subparsers(dest="lateral_cmd", required=True)
    lps.add_parser("paths")
    li = lps.add_parser("ingest")
    lis = li.add_subparsers(dest="lateral_adapter", required=True)
    lb = lis.add_parser("bloodhound")
    lb.add_argument("--bh-dir", required=True, dest="bh_dir")
    lb.add_argument("--out", required=True)
    lb.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lb.add_argument("--run-id", default=None)
    lb.add_argument("--workload-id", default=None)
    ll = lis.add_parser("ldapdomaindump")
    ll.add_argument("--dump-dir", required=True, dest="dump_dir")
    ll.add_argument("--out", required=True)
    ll.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    ll.add_argument("--run-id", default=None)
    ll.add_argument("--workload-id", default=None)
    lm = lis.add_parser("manual")
    lm.add_argument("--input", required=True)
    lm.add_argument("--out", required=True)
    lm.add_argument("--attack-path-id", default="ad_kerberoast_v1")
    lm.add_argument("--run-id", default=None)
    lm.add_argument("--workload-id", default=None)
    lpr = lps.add_parser("project")
    lpr.add_argument("--in", dest="infile", required=True)
    lpr.add_argument("--out", dest="outfile", required=True)
    lpr.add_argument("--attack-path-id", required=True)
    ll2 = lps.add_parser("latest")
    ll2.add_argument("--interp", required=True)
    ll2.add_argument("--attack-path-id", required=True)
    ll2.add_argument("--workload-id", default=None)

    a = p.parse_args()
    dispatch = {
        "calibrate": cmd_calibrate,
        "engage":    cmd_engage,
        "audit":     cmd_audit,
        "data":      cmd_data,
        "exploit":   cmd_exploit,
        "graph":     cmd_graph,
        "folds":     cmd_folds,
        "collect":   cmd_collect,
        "start":     cmd_start,
        "stop":      cmd_stop,
        "status":    cmd_status,
        "surface":   cmd_surface,
        "web":       cmd_web_view,
        "target":    cmd_target,
        "observe":   cmd_observe,
        "derived":   cmd_derived,
        "report":    cmd_report,
        "gravity":   cmd_gravity,
        "proposals": cmd_proposals,
        "mode":      cmd_mode,
        "feed":      cmd_feed,
        "resonance": cmd_resonance,
        "identity":  cmd_identity,
        "field":     cmd_field,
        "catalog":   cmd_catalog,
        "aprs":      cmd_aprs,
        "escape":    cmd_escape,
        "lateral":   cmd_lateral,
        "check":     cmd_check,
        "replay":    cmd_replay,
    }
    dispatch.get(a.command, lambda _: p.print_help())(a)


if __name__ == "__main__":
    main()
