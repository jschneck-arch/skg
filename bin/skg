#!/usr/bin/env python3
"""
skg — Unified CLI for Semantic Kernel Gravity

DAEMON (requires running daemon on 127.0.0.1:5055):
  skg status
  skg mode [kernel|resonance|unified|anchor] [--reason "..."]
  skg identity [history]

RESONANCE (runs directly, no daemon needed):
  skg resonance status
  skg resonance ingest
  skg resonance query <text> [--type all|wickets|adapters|domains] [--k N]
  skg resonance draft-prompt <domain> <description>
  skg resonance draft-accept <domain> <response.json|->
  skg resonance drafts

HOST COLLECTION (active target assessment):
  skg host ingest ssh --host <ip> --user <user> [--key <path>|--password <pw>] --out <file>
  skg host ingest winrm --host <ip> --user <user> --password <pw> --out <file>
  skg host ingest nmap [--xml <file>|--target <cidr>] --out <file>
  skg host ingest msf_session [--rpc-host <ip>|--json-dump <file>] --out <file>
  skg host project --in <events> --out <interp> --attack-path-id <id>
  skg host latest --interp <file> --attack-path-id <id>
  skg host paths

COLLECT (daemon-driven sweep):
  skg collect                          # sweep all targets.yaml
  skg collect --target <ip> [options]  # single host

APRS:
  skg aprs ingest config_effective --root <path> --out <file> [options]
  skg aprs ingest net_sandbox --docker-inspect <path> --out <file> [options]
  skg aprs project --in <events> --out <interp> --attack-path-id <id>
  skg aprs latest --interp <file> --attack-path-id <id>
  skg aprs paths

CONTAINER ESCAPE:
  skg escape ingest --inspect <path> --out <file> [options]
  skg escape project --in <events> --out <interp> --attack-path-id <id>
  skg escape latest --interp <file> --attack-path-id <id>
  skg escape paths

AD LATERAL:
  skg lateral ingest bloodhound --bh-dir <path> --out <file> [options]
  skg lateral ingest ldapdomaindump --dump-dir <path> --out <file> [options]
  skg lateral ingest manual --input <path> --out <file> [options]
  skg lateral project --in <events> --out <interp> --attack-path-id <id>
  skg lateral latest --interp <file> --attack-path-id <id>
  skg lateral paths
"""
import json, sys, argparse, subprocess, urllib.request, urllib.error
from pathlib import Path

API      = "http://127.0.0.1:5055"
SKG_HOME = Path(__file__).resolve().parent.parent


def _api(method, path, data=None):
    url  = f"{API}{path}"
    body = json.dumps(data).encode() if data else None
    hdrs = {"Content-Type": "application/json"} if body else {}
    req  = urllib.request.Request(url, data=body, headers=hdrs, method=method)
    try:
        with urllib.request.urlopen(req, timeout=5) as r:
            return json.loads(r.read())
    except urllib.error.URLError:
        print("Error: SKG daemon not running.  Start: systemctl --user start skg")
        sys.exit(1)
    except urllib.error.HTTPError as e:
        print(f"Error: {json.loads(e.read()).get('detail', str(e))}")
        sys.exit(1)


def _tc(tc_name, cli_script, *args):
    tc_dir = SKG_HOME / tc_name
    py     = tc_dir / ".venv" / "bin" / "python"
    cli    = tc_dir / cli_script
    if not py.exists():
        print(f"Error: {tc_name} not bootstrapped.\n  cd {tc_dir} && ./bootstrap.sh")
        return 1
    return subprocess.call([str(py), str(cli)] + list(args), cwd=str(tc_dir))


def _aprs(*args):    return _tc("skg-aprs-toolchain",             "skg.py",         *args)
def _escape(*args):  return _tc("skg-container-escape-toolchain", "skg_escape.py",  *args)
def _lateral(*args): return _tc("skg-ad-lateral-toolchain",       "skg_lateral.py", *args)
def _host(*args):    return _tc("skg-host-toolchain",             "skg_host.py",    *args)


def _resonance_engine():
    sys.path.insert(0, str(SKG_HOME))
    from skg.resonance.engine import ResonanceEngine
    from skg.core.paths import RESONANCE_DIR
    engine = ResonanceEngine(RESONANCE_DIR)
    engine.boot()
    return engine


# ---------------------------------------------------------------------------
# Daemon commands
# ---------------------------------------------------------------------------

def cmd_status(a):
    d = _api("GET", "/status")
    print(f"  Status  : {d['status']}")
    print(f"  Mode    : {d['mode']} — {d['mode_description']}")
    print(f"  TC runs : {'enabled' if d['toolchain_runs_enabled'] else 'disabled in this mode'}")
    print(f"  Started : {d['started_at']}")
    print()
    print("  Toolchains:")
    for domain, status in d.get("toolchains", {}).items():
        print(f"    {domain}: {status}")
    print()
    rs = d.get("resonance", {})
    if rs.get("ready"):
        mem = rs.get("memory", {})
        print(f"  Resonance: ready ({rs.get('embedder','?')} dim={rs.get('dim','?')})")
        print(f"    wickets={mem.get('wickets',0)} "
              f"adapters={mem.get('adapters',0)} "
              f"domains={mem.get('domains',0)}")
    else:
        print(f"  Resonance: {rs.get('reason', 'not ready')}")
    print()
    i = d['identity']
    print(f"  Identity: {i['name']} v{i['version']} | "
          f"coherence={i['coherence']} | sessions={i['sessions']}")


def cmd_mode(a):
    if a.set_mode:
        t = _api("POST", "/mode", {"mode": a.set_mode, "reason": a.reason or ""})["transition"]
        print(f"  Mode: {t['from']} → {t['to']}" +
              (f"\n  Reason: {t['reason']}" if t.get("reason") else ""))
    else:
        d = _api("GET", "/mode")
        print(f"  Mode: {d['mode']}\n  {d['description']}")


def cmd_identity(a):
    if getattr(a, "subcommand", None) == "history":
        for r in _api("GET", "/identity/history"):
            print(f"  [{r['timestamp']}] mode={r['mode']} "
                  f"coherence={r['coherence']} src={r['source']}")
    else:
        for k, v in _api("GET", "/identity").items():
            if k not in ("timestamp", "source"):
                print(f"  {k}: {v}")


# ---------------------------------------------------------------------------
# Resonance commands (direct — no daemon needed)
# ---------------------------------------------------------------------------

def cmd_resonance(a):
    subcmd = a.resonance_cmd

    if subcmd == "status":
        engine = _resonance_engine()
        print(json.dumps(engine.status(), indent=2))

    elif subcmd == "ingest":
        from skg.resonance.ingester import ingest_all
        from skg.core.paths import RESONANCE_DIR
        engine = _resonance_engine()
        summary = ingest_all(engine, SKG_HOME)
        print(json.dumps(summary, indent=2))

    elif subcmd == "query":
        engine = _resonance_engine()
        k = getattr(a, "k", 5) or 5
        qtype = getattr(a, "type", "all") or "all"
        if qtype in ("wickets", "all"):
            results = engine.query_wickets(a.text, k=k)
            print(f"\n=== Wickets (top {len(results)}) ===")
            for rec, score in results:
                print(f"  [{score:.3f}] {rec.record_id}")
                print(f"    {rec.label}")
                print(f"    {rec.description[:80]}")
        if qtype in ("adapters", "all"):
            results = engine.query_adapters(a.text, k=k)
            print(f"\n=== Adapters (top {len(results)}) ===")
            for rec, score in results:
                print(f"  [{score:.3f}] {rec.record_id}")
                print(f"    {'; '.join(rec.evidence_sources[:2])}")
        if qtype in ("domains", "all"):
            results = engine.query_domains(a.text, k=min(k, 3))
            print(f"\n=== Domains (top {len(results)}) ===")
            for rec, score in results:
                print(f"  [{score:.3f}] {rec.domain} — {rec.description[:80]}")

    elif subcmd == "draft-prompt":
        from skg.resonance.drafter import draft_prompt
        engine = _resonance_engine()
        print(f"[*] Building grounded prompt for: {a.domain}")
        result = draft_prompt(engine, a.domain, a.description)
        ctx = result["context_used"]
        print(f"[*] Memory context: {ctx['wickets_surfaced']} wickets, "
              f"{ctx['adapters_surfaced']} adapters, "
              f"{ctx['domains_surfaced']} domains surfaced")
        print(f"\n[*] Prompt written to:")
        print(f"    {result['prompt_path']}")
        print(f"\n[*] Pending draft marker:")
        print(f"    {result['pending_path']}")
        print(f"\n{'='*60}")
        print("PASTE THE FOLLOWING INTO CLAUDE.AI:")
        print('='*60)
        print(result["prompt"])
        print('='*60)
        print(f"\nThen run:")
        print(f"  skg resonance draft-accept {a.domain} <path-to-response.json>")
        print(f"  # or pipe the JSON directly:")
        print(f"  skg resonance draft-accept {a.domain} -")

    elif subcmd == "draft-accept":
        from skg.resonance.drafter import draft_accept
        import sys as _sys
        engine = _resonance_engine()
        # Read from file path or stdin (-)
        source = a.response
        if source == "-":
            print("[*] Reading JSON from stdin (paste response, then Ctrl+D)...")
            response_json = _sys.stdin.read()
        else:
            response_json = source  # draft_accept handles file path or raw JSON
        result = draft_accept(engine, a.domain, response_json)
        errors = result["validation_errors"]
        if errors:
            print(f"\n[WARN] Validation issues ({len(errors)}):")
            for e in errors:
                print(f"  - {e}")
        else:
            print("[OK] Draft passed validation")
        print(f"[*] Wickets:      {len(result['catalog'].get('wickets', {}))}")
        print(f"[*] Attack paths: {len(result['catalog'].get('attack_paths', {}))}")
        print(f"[*] Draft saved:  {result['draft_path']}")
        print(f"\nTo promote to a toolchain:")
        print(f"  cp {result['draft_path']} /opt/skg/skg-{a.domain}-toolchain/contracts/catalogs/")

    elif subcmd == "drafts":
        engine = _resonance_engine()
        drafts = engine.list_drafts()
        if not drafts:
            print("No pending drafts.")
            return
        print(f"{len(drafts)} pending draft(s):\n")
        for d in drafts:
            meta = d.get("meta", {})
            print(f"  {d['file']}")
            print(f"    domain:  {meta.get('domain', '?')}")
            print(f"    drafted: {meta.get('drafted_at', '?')}")
            print(f"    status:  {meta.get('status', '?')}")

    elif subcmd == "draft-generate":
        # Fully local: resonance context → ollama → catalog draft
        from skg.resonance.drafter import draft_catalog
        engine = _resonance_engine()
        print(f"[*] Generating catalog for: {a.domain}")
        print(f"[*] Using local ollama backend")
        result = draft_catalog(engine, a.domain, a.description)
        backend = result.get("backend", "api")
        model   = result.get("model", "")
        ctx     = result.get("context_used", {})
        errors  = result.get("validation_errors", [])
        print(f"[*] Backend:      {backend}" + (f" ({model})" if model else ""))
        print(f"[*] Context:      {ctx.get('wickets_surfaced',0)} wickets, "
              f"{ctx.get('adapters_surfaced',0)} adapters, "
              f"{ctx.get('domains_surfaced',0)} domains")
        if errors:
            print(f"[WARN] Validation issues:")
            for e in errors:
                print(f"  - {e}")
        else:
            print("[OK] Draft passed validation")
        print(f"[*] Wickets:      {len(result['catalog'].get('wickets', {}))}")
        print(f"[*] Attack paths: {len(result['catalog'].get('attack_paths', {}))}")
        print(f"[*] Draft saved:  {result['draft_path']}")
        print(f"\nReview with:  cat {result['draft_path']}")
        print(f"Promote with: cp {result['draft_path']} /opt/skg/skg-{a.domain}-toolchain/contracts/catalogs/")

    elif subcmd == "ollama":
        from skg.resonance.ollama_backend import OllamaBackend
        backend = OllamaBackend()
        status  = backend.status()
        print(f"Ollama available: {status['available']}")
        print(f"URL:              {status['url']}")
        if status['available']:
            print(f"Models:           {', '.join(status['models']) or 'none'}")
            print(f"Selected:         {status['selected_model'] or 'none'}")
            print(f"Temperature:      {status['temperature']}")
        else:
            print()
            print("To enable local catalog generation:")
            print("  ollama serve")
            print("  ollama pull llama3.2:3b   # ~2GB, fast, good for structured output")
            print("  ollama pull mistral:7b    # ~4GB, better reasoning")


# ---------------------------------------------------------------------------
# Train — corpus management and fine-tune scheduling
# ---------------------------------------------------------------------------

def cmd_train(a):
    """Training corpus and fine-tune pipeline."""
    subcmd = a.train_cmd

    if subcmd == "status":
        from skg.training.trainer import training_status
        from skg.training.scheduler import scheduler_status
        ts = training_status()
        ss = scheduler_status()
        hw = ts["hardware"]

        print("\n=== SKG Training System ===\n")
        print(f"Hardware:")
        print(f"  GPU:       {hw.get('gpu') or 'none (CPU only)'}")
        if hw.get('gpu'):
            print(f"  GPU mem:   {hw.get('gpu_mem_gb')}GB")
        print(f"  Backend:   {hw.get('backend')}")
        print(f"  CPU cores: {hw.get('cpu_cores')}")
        print(f"  Unsloth:   {'installed' if ts['has_unsloth'] else 'not installed'}")
        print()

        corpus = ts["corpus"]
        print(f"Corpus:")
        print(f"  Total examples:    {corpus['total']}")
        print(f"  Positive:          {corpus['positive']}")
        print(f"  Negative:          {corpus['negative']}")
        print(f"  New since run:     {corpus['examples_since_last_run']}")
        print(f"  Min for run:       {corpus['min_required']}")
        print(f"  Ready:             {'YES' if corpus['ready_for_run'] else 'no'}")
        if corpus.get("by_kind"):
            print(f"  By kind:           {corpus['by_kind']}")
        if corpus.get("by_source"):
            print(f"  By source:         {corpus['by_source']}")
        print()

        print(f"Scheduler:")
        print(f"  Last run:          {ss['last_triggered_at'] or 'never'}")
        print(f"  Hours since:       {ss['hours_since_last']}")
        print(f"  On battery:        {ss['on_battery']}")
        print(f"  System load:       {ss['system_load']}")
        print(f"  Ready to run:      {'YES' if ss['ready'] else 'no'}")
        if not ss['ready']:
            print(f"  Reason:            {ss['next_condition']}")
        print()

        print(f"Model:")
        print(f"  Active:            {ts['active_model']}")
        if ts.get("last_run"):
            lr = ts["last_run"]
            print(f"  Last run:          {lr.get('run_id')}")
            print(f"  Last eval score:   {lr.get('eval_score')}")
            print(f"  Model swapped:     {lr.get('model_swapped')}")
        print()

        if not ts["has_unsloth"]:
            print("  Install unsloth for fine-tuning:")
            print("    pip install unsloth")
            print("    # or for CPU-only:")
            print("    pip install unsloth[cpu]")

    elif subcmd == "run":
        wait = getattr(a, "wait", False)
        force = getattr(a, "force", False)
        if wait:
            from skg.training.scheduler import trigger_sync
            print("[*] Running training synchronously (this may take hours)...")
            result = trigger_sync(force=force)
        else:
            from skg.training.scheduler import trigger
            result = trigger(force=force)
        print(json.dumps(result, indent=2))

    elif subcmd == "corpus":
        from skg.training.corpus import load_all_examples, corpus_status
        sub2 = getattr(a, "corpus_cmd", "status")

        if sub2 == "list":
            examples = load_all_examples(
                label=getattr(a, "label", None),
                kind=getattr(a, "kind", None),
            )
            for ex in examples[-20:]:
                print(f"  [{ex['id'][:8]}] {ex['label']:8s} {ex['kind']:12s} "
                      f"{ex['domain']:15s} {ex['source']:20s} {ex['ts'][:16]}")
            print(f"\n  Total: {len(examples)}")

        elif sub2 == "add":
            # Manual positive example add
            from skg.training.corpus import add_example
            eid = add_example(
                kind=a.kind, label="positive",
                source="manual", domain=a.domain,
                input_text=open(a.input_file).read(),
                output_text=open(a.output_file).read(),
                metadata={"note": "manually added"},
            )
            print(f"[OK] Added example: {eid[:8]}")

        elif sub2 == "clear":
            # Clear corpus (confirmation required)
            resp = input("Clear entire training corpus? [y/N] ")
            if resp.lower() == "y":
                from skg.training.corpus import EXAMPLES_DIR
                import shutil
                if EXAMPLES_DIR.exists():
                    shutil.rmtree(EXAMPLES_DIR)
                    EXAMPLES_DIR.mkdir(parents=True)
                print("[OK] Corpus cleared.")

    elif subcmd == "install-unsloth":
        import subprocess, sys
        hw = __import__("skg.training.trainer", fromlist=["detect_hardware"]).detect_hardware()
        if hw["backend"] == "nvidia":
            pkg = "unsloth[colab-new]"
        elif hw["backend"] == "amd":
            pkg = "unsloth[cpu]"
        else:
            pkg = "unsloth[cpu]"
        venv_pip = Path("/opt/skg/.venv/bin/pip")
        pip = str(venv_pip) if venv_pip.exists() else "pip"
        print(f"[*] Installing {pkg}...")
        subprocess.run([pip, "install", pkg, "--no-cache-dir"])

    elif subcmd == "rollback":
        # TODO: restore previous model tag in ollama backend config
        print("[!] Rollback: set previous model tag in ollama backend config")
        print("    skg resonance ollama  — see current model")


# ---------------------------------------------------------------------------
# Surface — operator picture
# ---------------------------------------------------------------------------

def cmd_surface(a):
    """Full engagement surface: projection results + delta + gaps + proposals."""
    import os
    from skg.intel.surface import full_report, surface, delta_report, next_actions
    from skg.intel.gap_detector import detect_from_events
    from skg.forge.proposals import list_proposals, format_proposal_list
    from skg.core.paths import INTERP_DIR, EVENTS_DIR

    subcmd = getattr(a, "surface_cmd", "report")

    if subcmd == "report" or subcmd is None:
        gaps   = detect_from_events(EVENTS_DIR)
        report = full_report(interp_dir=INTERP_DIR, gaps=gaps)
        surf   = report["surface"]
        delta  = report["delta"]
        acts   = report["next_actions"]
        props  = list_proposals("pending")

        print(f"\n{'='*60}")
        print(f"  SKG ENGAGEMENT SURFACE")
        print(f"  {report['generated_at'][:19]}")
        print(f"{'='*60}\n")

        # Summary
        s = surf["summary"]
        print(f"WORKLOADS:  {s['total_workloads']} evaluated  |  "
              f"realized={s['realized_paths']}  "
              f"indeterminate={s['indeterminate_paths']}  "
              f"not_realized={s['not_realized_paths']}")

        # Delta
        dc = delta.get("counts", {})
        print(f"DELTA 24h:  +{dc.get('expansions',0)} expansions  "
              f"-{dc.get('remediations',0)} remediations  "
              f"~{dc.get('regressions',0)} regressions")

        # Coverage gaps
        all_gaps = report.get("coverage_gaps", [])
        print(f"GAPS:       {len(all_gaps)} uncovered service(s)")
        print(f"PROPOSALS:  {len(props)} pending")
        print()

        # Realized paths
        if s["top_realized"]:
            print("REALIZED ATTACK PATHS:")
            for r in s["top_realized"]:
                print(f"  ● {r['workload_id']:30s} {r['domain']:25s} "
                      f"score={r['score']:.2f}")
            print()

        # Next actions
        if acts:
            print("NEXT ACTIONS (ranked):")
            for i, act in enumerate(acts[:8], 1):
                priority_label = {1:"EXPLOIT",2:"COLLECT",3:"FORGE",4:"INVESTIGATE"}.get(
                    act["priority"], "ACTION")
                if act["action"] == "exploit":
                    print(f"  {i}. [{priority_label}] {act['workload_id']} — "
                          f"{act['domain']} ({act['attack_path']})")
                elif act["action"] == "collect":
                    print(f"  {i}. [{priority_label}] {act['workload_id']} — "
                          f"{len(act.get('unknown_wickets',[]))} unknown wickets")
                elif act["action"] == "generate_toolchain":
                    print(f"  {i}. [{priority_label}] {act['service']} on "
                          f"{len(act.get('hosts',[]))} host(s) — {act['detail'][:50]}")
                    print(f"          → {act.get('forge_cmd','')}")
                elif act["action"] == "investigate_control":
                    print(f"  {i}. [{priority_label}] {act['workload_id']} — "
                          f"single block: {act.get('blocked_wicket','')}")
            print()

        # Pending proposals
        if props:
            print("PENDING TOOLCHAIN PROPOSALS:")
            for p in props[:5]:
                val_icon = "✓" if p.get("validation",{}).get("passed") else "⚠"
                print(f"  {val_icon} [{p['id'][:8]}] {p['domain']:20s} "
                      f"{p.get('wicket_count',0)}w  "
                      f"{len(p.get('hosts',[]))} host(s)  "
                      f"{p.get('attack_surface','')[:45]}")
            print()
            print("  skg proposals list    — full proposal list")
            print("  skg proposals accept <id>  — install toolchain")

        # Workload detail if --verbose
        if getattr(a, "verbose", False):
            print("\nALL WORKLOADS:")
            for w in surf["workloads"]:
                sym = {"realized":"●","indeterminate":"◐","not_realized":"○"}.get(
                    w["classification"], "?")
                print(f"  {sym} {w['workload_id']:35s} {w['domain_label']:20s} "
                      f"score={w['score']:.2f}  realized={len(w['realized'])}  "
                      f"blocked={len(w['blocked'])}  unknown={len(w['unknown'])}")

        # Surface expansions
        if delta.get("surface_expansions"):
            print("\nSURFACE EXPANSIONS (24h):")
            for t in delta["surface_expansions"][:5]:
                print(f"  + {t['workload_id']:30s} {t['wicket_id']}  "
                      f"{t['ts'][:16]}")

    elif subcmd == "json":
        gaps   = detect_from_events(EVENTS_DIR)
        report = full_report(interp_dir=INTERP_DIR, gaps=gaps)
        print(json.dumps(report, indent=2))

    elif subcmd == "gaps":
        from skg.core.paths import EVENTS_DIR
        gaps = detect_from_events(EVENTS_DIR)
        if not gaps:
            print("No coverage gaps detected.")
            return
        print(f"{len(gaps)} coverage gap(s):\n")
        for g in gaps:
            print(f"  {g['service']:20s} [{g['category']}]  "
                  f"hosts: {', '.join(g['hosts'][:3])}")
            print(f"    {g['attack_surface'][:72]}")
            print(f"    forge: skg forge generate {g['service']}")
            print()

    elif subcmd == "workloads":
        surf = surface(INTERP_DIR)
        for w in surf["workloads"]:
            sym = {"realized":"●","indeterminate":"◐","not_realized":"○"}.get(
                w["classification"], "?")
            print(f"{sym} {w['workload_id']}  [{w['domain_label']}]  "
                  f"score={w['score']}  {w['classification']}")
            if getattr(a, "verbose", False):
                if w["realized"]:
                    print(f"  realized: {', '.join(w['realized'])}")
                if w["blocked"]:
                    print(f"  blocked:  {', '.join(w['blocked'])}")
                if w["unknown"]:
                    print(f"  unknown:  {', '.join(w['unknown'])}")


# ---------------------------------------------------------------------------
# Proposals
# ---------------------------------------------------------------------------

def cmd_proposals(a):
    """Toolchain proposal queue — review and accept/reject generated toolchains."""
    from skg.forge.proposals import (
        list_proposals, get, accept, reject, defer,
        format_proposal_list, format_proposal_detail,
    )

    subcmd = a.proposals_cmd

    if subcmd == "list":
        status = getattr(a, "status", "pending") or "pending"
        props  = list_proposals(status)
        print(format_proposal_list(props, verbose=getattr(a, "verbose", False)))

    elif subcmd == "show":
        proposal = get(a.id)
        if not proposal:
            print(f"Proposal not found: {a.id}")
            return
        print(format_proposal_detail(proposal))

    elif subcmd == "accept":
        try:
            result = accept(a.id)
            print(f"[OK] Installed: {result['domain']}")
            print(f"     Path:      {result['installed_path']}")
            print(f"     Wickets:   {result['wicket_count']}")
            print(f"     Paths:     {result['path_count']}")
            print(f"\n     {result['next']}")
        except Exception as exc:
            print(f"[ERR] {exc}")

    elif subcmd == "reject":
        reason = getattr(a, "reason", "") or ""
        try:
            result = reject(a.id, reason=reason)
            print(f"[OK] Rejected: {result['domain']}")
            print(f"     Cooldown until: {result['cooldown_until']}")
        except Exception as exc:
            print(f"[ERR] {exc}")

    elif subcmd == "defer":
        days = getattr(a, "days", 7) or 7
        try:
            result = defer(a.id, days=days)
            print(f"[OK] Deferred: {result['domain']} until {result['until']}")
        except Exception as exc:
            print(f"[ERR] {exc}")


# ---------------------------------------------------------------------------
# Forge — manual toolchain generation
# ---------------------------------------------------------------------------

def cmd_forge(a):
    """Toolchain forge — manually trigger generation for a service/domain."""
    subcmd = a.forge_cmd

    if subcmd == "generate":
        from skg.forge.generator import generate_toolchain
        from skg.forge.validator import validate, validation_summary
        from skg.forge.proposals import create
        from skg.intel.gap_detector import KNOWN_SERVICES, _collection_hints

        domain = a.domain.lower().replace(" ", "_").replace("-", "_")
        description = getattr(a, "description", None) or             next((v[1] for k,v in KNOWN_SERVICES.items() if v[0] == domain), domain)

        # Build a synthetic gap record
        gap = {
            "service":          domain,
            "category":         "manual",
            "hosts":            getattr(a, "hosts", "").split(",") if getattr(a, "hosts", "") else [],
            "attack_surface":   description,
            "evidence":         "manual generation request",
            "detail":           f"Operator-requested toolchain for {domain}",
            "collection_hints": _collection_hints(domain),
            "forge_ready":      True,
        }

        print(f"[*] Generating toolchain: {domain}")
        print(f"[*] Description: {description[:72]}")

        try:
            engine = _resonance_engine()
        except Exception:
            engine = None
            print("[!] Resonance engine unavailable — generating without context grounding")

        result = generate_toolchain(domain, description, gap,
                                     resonance_engine=engine,
                                     force=getattr(a, "force", False))

        if not result.get("success"):
            print(f"[ERR] Generation failed:")
            for e in result.get("errors", []):
                print(f"      {e}")
            return

        print(f"[OK] Generated: {result['tc_name']}")
        print(f"     Wickets:   {result.get('wicket_count', 0)}")
        print(f"     Paths:     {result.get('path_count', 0)}")
        print(f"     Backend:   {result.get('generation_backend','')}")
        print(f"     Staged:    {result['staging_path']}")

        if result.get("errors"):
            print(f"[!] Warnings:")
            for e in result["errors"]:
                print(f"    {e}")

        # Validate
        print(f"\n[*] Validating...")
        val = validate(Path(result["staging_path"]))
        print(validation_summary(val))

        # Create proposal
        if not getattr(a, "no_propose", False):
            from skg.forge.proposals import create as create_proposal
            proposal = create_proposal(
                domain=domain, description=description, gap=gap,
                generation_result=result, validation_result=val,
            )
            print(f"\n[*] Proposal created: {proposal['id'][:8]}")
            print(f"    skg proposals accept {proposal['id'][:8]}")
            print(f"    skg proposals show   {proposal['id'][:8]}")

    elif subcmd == "list-staged":
        from skg.forge.generator import FORGE_STAGING
        if not FORGE_STAGING.exists():
            print("No staged toolchains.")
            return
        for d in sorted(FORGE_STAGING.iterdir()):
            if d.is_dir():
                meta_f = d / "forge_meta.json"
                if meta_f.exists():
                    try:
                        meta = json.loads(meta_f.read_text())
                        print(f"  {d.name}")
                        print(f"    generated: {meta.get('generated_at','')[:19]}")
                        print(f"    backend:   {meta.get('generation_backend','')}")
                    except Exception:
                        print(f"  {d.name}")
                else:
                    print(f"  {d.name}")

    elif subcmd == "pipeline":
        # Manually run the full forge pipeline
        from skg.forge.pipeline import run_forge_pipeline
        from skg.core.paths import EVENTS_DIR
        print("[*] Running forge pipeline...")
        try:
            engine = _resonance_engine()
        except Exception:
            engine = None
        summary = run_forge_pipeline(events_dir=EVENTS_DIR, resonance_engine=engine)
        print(f"[*] Gaps detected:  {summary['gaps_detected']}")
        print(f"[*] Gaps skipped:   {summary['gaps_skipped']}")
        print(f"[*] Generated:      {summary['generated']}")
        print(f"[*] Validated:      {summary['validated']}")
        print(f"[*] Proposed:       {summary['proposed']}")
        if summary["proposal_ids"]:
            print(f"[*] Proposal IDs:   {[p[:8] for p in summary['proposal_ids']]}")
        if summary["errors"]:
            print(f"[!] Errors:")
            for e in summary["errors"]:
                print(f"    {e}")


# ---------------------------------------------------------------------------
# APRS
# ---------------------------------------------------------------------------



def cmd_aprs(a):
    subcmd = a.aprs_cmd
    if subcmd == "paths":
        sys.exit(_aprs("paths"))
    elif subcmd == "ingest":
        args = ["ingest", a.adapter, "--out", a.out,
                "--attack-path-id", a.attack_path_id]
        if getattr(a, "run_id",         None): args += ["--run-id",         a.run_id]
        if getattr(a, "workload_id",    None): args += ["--workload-id",    a.workload_id]
        if getattr(a, "root",           None): args += ["--root",           a.root]
        if getattr(a, "docker_inspect", None): args += ["--docker-inspect", a.docker_inspect]
        if getattr(a, "resolv_conf",    None): args += ["--resolv-conf",    a.resolv_conf]
        if getattr(a, "iptables",       None): args += ["--iptables",       a.iptables]
        if getattr(a, "ps",             None): args += ["--ps",             a.ps]
        sys.exit(_aprs(*args))
    elif subcmd == "project":
        sys.exit(_aprs("project", "aprs",
                       "--in", a.infile, "--out", a.outfile,
                       "--attack-path-id", a.attack_path_id))
    elif subcmd == "latest":
        args = ["latest", "--interp", a.interp, "--attack-path-id", a.attack_path_id]
        if a.workload_id: args += ["--workload-id", a.workload_id]
        sys.exit(_aprs(*args))


