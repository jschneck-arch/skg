[Unit]
Description=SKG — Semantic Kernel Gravity Daemon
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/skg
ExecStart=/opt/skg/.venv/bin/python -m skg.core.daemon
Restart=on-failure
RestartSec=5s
TimeoutStopSec=10s

# Runtime paths
Environment=SKG_HOME=/opt/skg
Environment=SKG_STATE_DIR=/var/lib/skg
Environment=SKG_CONFIG_DIR=/etc/skg

# Output goes to journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=skg

[Install]
WantedBy=default.target
