# SKG secrets — /etc/skg/skg.env
# chmod 600 /etc/skg/skg.env after editing
# systemd reads this file via EnvironmentFile=

# NVD API key — get from https://nvd.nist.gov/developers/request-an-api-key
NIST_NVD_API_KEY=

# Metasploit RPC password (if using MSF sensor)
MSF_PASSWORD=

# BloodHound CE password (if using bloodhound sensor)
BH_PASSWORD=

# Optional: override default paths
# SKG_HOME=/opt/skg
# SKG_STATE_DIR=/var/lib/skg
# SKG_CONFIG_DIR=/etc/skg
