{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skg.event.envelope.v1",
  "title": "SKG Event Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "ts",
    "type",
    "source",
    "payload",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Globally unique event id (UUID recommended)."
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "Event timestamp (RFC3339)."
    },
    "type": {
      "type": "string",
      "description": "Event type, e.g. obs.attack.precondition"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "toolchain",
        "version"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "description": "Emitter id (adapter/projection)."
        },
        "toolchain": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "payload": {
      "type": "object",
      "description": "Type-specific payload."
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_rank",
        "evidence"
      ],
      "properties": {
        "evidence_rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "description": "1=runtime,2=build/classpath,3=config/filesystem,4=network,5=static,6=scanner"
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_kind",
            "pointer",
            "collected_at"
          ],
          "properties": {
            "source_kind": {
              "type": "string",
              "description": "e.g., jfr, firewall, config, static, scanner"
            },
            "pointer": {
              "type": "string",
              "description": "Opaque pointer to evidence artifact/log line/query (non-secret)."
            },
            "collected_at": {
              "type": "string",
              "format": "date-time"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    }
  }
}